# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Terraform CLI config files
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variable files (often contain secrets)
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Plan output files
*.tfplan
*.plan

# Ignore local lock file for module-style repos
.terraform.lock.hcl
